# Client-visible (shipped in browser bundle) — never put server secrets here

# Express API base URL (dev default when unset: http://localhost:3011)
NEXT_PUBLIC_SERVER_URL=http://localhost:3011

# Legacy alias — prefer NEXT_PUBLIC_SERVER_URL
# NEXT_PUBLIC_API_URL=http://localhost:3011

# Landing / footer links (optional)
NEXT_PUBLIC_GITHUB_ORG=Luckee-Core
NEXT_PUBLIC_GITHUB_WEB_URL=https://github.com/Luckee-Core/personal-finances
NEXT_PUBLIC_GITHUB_API_URL=https://github.com/Luckee-Core/personal-finances-express-server
NEXT_PUBLIC_DOCS_URL=https://github.com/Luckee-Core/personal-finances#readme
NEXT_PUBLIC_THT_URL=https://www.trouthousetech.com
